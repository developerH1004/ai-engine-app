name: AI Database Auto Update
on:
  schedule:
    - cron: '0 9 * * *'  # 매일 09:00 UTC (필리핀 17:00)
  workflow_dispatch:

jobs:
  update-ai-database:
    runs-on: ubuntu-latest

    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: |
          pip install requests pandas supabase python-dotenv groq

      - name: Run AI update collector
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
          GROQ_API_KEY: ${{ secrets.GROQ_API_KEY }}
        run: |
          python scripts/auto_update.py

      - name: Commit update log
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git remote set-url origin https://x-access-token:${{ secrets.GITHUB_TOKEN }}@github.com/${{ github.repository }}
          git add logs/
          git diff --staged --quiet || git commit -m "Auto update: $(date +'%Y-%m-%d')"
          git push
